{
	"name": "easyphysic",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"description": "Modern physics learning platform with ViteJS",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
		"preview": "vite preview",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"framer-motion": "^12.29.2",
		"lucide-react": "^0.512.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-icons": "^5.5.0",
		"react-router-dom": "^7.0.0",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@types/node": "^22.14.0",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.29.0",
		"@typescript-eslint/parser": "^8.29.0",
		"@vitejs/plugin-react": "^5.1.1",
		"@vitest/coverage-v8": "^3.0.3",
		"@vitest/ui": "^3.0.3",
		"autoprefixer": "^10.4.20",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"postcss": "^8.5.1",
		"tailwindcss": "^3.4.18",
		"typescript": "^5.6.3",
		"vite": "^7.2.4",
		"vitest": "^3.0.3"
	},
	"keywords": [
		"physics",
		"education",
		"ege",
		"learning",
		"vite"
	],
	"author": "EasyPhysics Team",
	"license": "MIT"
}
